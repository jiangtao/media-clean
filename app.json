{
  "expo": {
    "name": "MediaClean",
    "slug": "mistap-media-cleaner",
    "version": "0.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.jt.mistapmediacleaner"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundImage": "./assets/adaptive-icon-background.png",
        "monochromeImage": "./assets/adaptive-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jt.mistapmediacleaner",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash-brand-light.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/splash-brand-dark.png"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "允许 MediaClean 读取你的照片与视频，以便识别疑似误触媒体。",
          "savePhotosPermission": "允许 MediaClean 在你确认时删除或整理媒体。",
          "granularPermissions": [
            "photo",
            "video"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "cleanup-reminders",
          "color": "#173944"
        }
      ],
      "./plugins/withAndroidReleaseSigning",
      "./plugins/withBackgroundScan",
      "expo-video"
    ]
  }
}
