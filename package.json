{
  "name": "app-cleaner",
  "version": "0.0.5",
  "main": "index.ts",
  "scripts": {
    "prepare": "node scripts/git/install-hooks.mjs --if-git",
    "hooks:install": "node scripts/git/install-hooks.mjs",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "agent-device": "bash scripts/android/run-agent-device.sh",
    "agent-device:workflow": "bash scripts/android/run-agent-device.sh help workflow",
    "agent-device:debugging": "bash scripts/android/run-agent-device.sh help debugging",
    "agent-device:react-devtools": "bash scripts/android/run-agent-device.sh help react-devtools",
    "seed:android:media": "bash scripts/android/seed-emulator-media.sh",
    "seed:android:scan-result": "bash scripts/android/seed-emulator-scan-result.sh",
    "seed:android:recycle-bin": "bash scripts/android/seed-emulator-recycle-bin.sh",
    "test": "vitest",
    "test:observability": "vitest --run src/services/observability src/application/__tests__/AppErrorBoundary.test.tsx src/application/__tests__/AppObservabilityBootstrap.test.tsx",
    "test:agent-device:observability": "bash scripts/android/run-agent-device-observability.sh capture --install-apk",
    "test:agent-device:smoke": "bash scripts/android/run-agent-device-observability.sh smoke --install-apk",
    "test:agent-device:acceptance": "bash scripts/android/run-agent-device-observability.sh acceptance --install-apk",
    "test:agent-device:scan-probe": "bash scripts/android/run-agent-device-observability.sh scan-probe --install-apk",
    "test:agent-device:scan-complete": "bash scripts/android/run-agent-device-observability.sh scan-complete --install-apk",
    "test:agent-device:continue-scan": "bash scripts/android/run-agent-device-observability.sh continue-scan --install-apk",
    "test:agent-device:permission-denied": "bash scripts/android/run-agent-device-observability.sh permission-denied --install-apk",
    "test:agent-device:scan-cleanup": "bash scripts/android/run-agent-device-observability.sh scan-cleanup --install-apk",
    "test:agent-device:settings-signoff": "bash scripts/android/run-agent-device-observability.sh settings-signoff",
    "test:agent-device:filtering-selection": "bash scripts/android/run-agent-device-observability.sh filtering-selection",
    "test:agent-device:recycle": "bash scripts/android/run-agent-device-observability.sh recycle",
    "test:agent-device:recycle-selection": "bash scripts/android/run-agent-device-observability.sh recycle-selection",
    "test:agent-device:recycle-delete": "bash scripts/android/run-agent-device-observability.sh recycle-delete",
    "test:maestro:smoke": "bash scripts/android/run-maestro-smoke.sh",
    "observability:device:doctor": "bash scripts/android/run-agent-device-observability.sh doctor",
    "observability:device:react": "bash scripts/android/run-agent-device-observability.sh react",
    "verify:android:observability": "bash scripts/android/run-agent-device-observability.sh capture --install-apk",
    "verify:android:acceptance": "bash scripts/android/run-agent-device-observability.sh acceptance --install-apk",
    "verify:android:scan-probe": "bash scripts/android/run-agent-device-observability.sh scan-probe --install-apk",
    "verify:android:scan-complete": "bash scripts/android/run-agent-device-observability.sh scan-complete --install-apk",
    "verify:android:continue-scan": "bash scripts/android/run-agent-device-observability.sh continue-scan --install-apk",
    "verify:android:permission-denied": "bash scripts/android/run-agent-device-observability.sh permission-denied --install-apk",
    "verify:android:scan-cleanup": "bash scripts/android/run-agent-device-observability.sh scan-cleanup --install-apk",
    "verify:android:settings-signoff": "bash scripts/android/run-agent-device-observability.sh settings-signoff",
    "verify:android:filtering-selection": "bash scripts/android/run-agent-device-observability.sh filtering-selection",
    "verify:android:recycle": "bash scripts/android/run-agent-device-observability.sh recycle",
    "verify:android:recycle-selection": "bash scripts/android/run-agent-device-observability.sh recycle-selection",
    "verify:android:recycle-delete": "bash scripts/android/run-agent-device-observability.sh recycle-delete",
    "test:gesture:swipe": "maestro test .maestro/gesture/swipe-selection.yaml",
    "test:gesture:zoom": "maestro test .maestro/gesture/pinch-zoom.yaml",
    "test:gesture:all": "maestro test .maestro/gesture/gesture-suite.yaml",
    "verify:android:v0-4-design-signoff": "bash scripts/android/run-v0-4-design-signoff.sh",
    "verify:android:v0-4-physical-signoff": "bash scripts/android/run-v0-4-design-signoff.sh --skip-emulator-matrix --skip-maestro --require-physical",
    "verify:device:lane": "bash scripts/device/run-validation-lane.sh",
    "verify:device:lane:android:emulator-core": "bash scripts/device/run-validation-lane.sh android emulator-core",
    "verify:device:lane:android:emulator-seeded": "bash scripts/device/run-validation-lane.sh android emulator-seeded",
    "verify:device:lane:android:real-device-core": "bash scripts/device/run-validation-lane.sh android real-device-core",
    "typecheck": "tsc --noEmit",
    "page:build": "cd page && npm run build",
    "page:dev": "cd page && npm run dev",
    "page:preview": "cd page && npm run preview",
    "page:deploy": "cd page && npm run deploy",
    "page:deploy:prod": "cd page && npm run deploy:prod",
    "export:android": "expo export --platform android",
    "prebuild:android": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "run:android:debug": "expo run:android --variant debug",
    "build:android:debug": "bash scripts/android/build-debug-apk.sh --skip-install",
    "build:android:debug:arm": "bash scripts/android/build-debug-apk.sh --skip-install --architectures armeabi-v7a,arm64-v8a",
    "build:android:debug:arm64": "bash scripts/android/build-debug-apk.sh --skip-install --architectures arm64-v8a",
    "build:android:validation": "bash scripts/android/build-validation-apk.sh --skip-install",
    "build:android:validation:legacy": "bash scripts/android/build-validation-apk.sh --skip-install --enable-legacy-packaging",
    "build:android:validation:legacy-shrink": "bash scripts/android/build-validation-apk.sh --skip-install --enable-legacy-packaging --enable-minify --enable-resource-shrink",
    "assemble:android:debug": "cd android && ./gradlew assembleDebug",
    "assemble:android:release": "cd android && ./gradlew assembleRelease",
    "prepare:android:keystore": "node scripts/android/prepare-keystore.mjs",
    "verify:android:debug": "node scripts/android/verify-debug-artifact.mjs android/app/build/outputs/apk/debug/app-debug.apk",
    "metadata:android:debug": "node scripts/android/collect-debug-metadata.mjs android/app/build/outputs/apk/debug/app-debug.apk",
    "verify:android:release": "node scripts/android/verify-release-artifact.mjs android/app/build/outputs/apk/release/app-release.apk",
    "metadata:android:release": "node scripts/android/collect-release-metadata.mjs android/app/build/outputs/apk/release/app-release.apk",
    "analyze:android:apk": "node scripts/android/analyze-apk-size.mjs",
    "analyze:android:deps": "node scripts/android/analyze-dependency-footprint.mjs",
    "compare:android:apk-size": "node scripts/android/compare-apk-size-reports.mjs",
    "verify:android:apk-size": "node scripts/android/analyze-apk-size.mjs android/app/build/outputs/apk/release/app-release.apk --out-dir artifacts/android-release --profile user-arm-only --fail-on-budget",
    "verify:precommit": "npm run verify:release:page-contract && npm run analyze:android:deps && node scripts/android/verify-apk-size-precommit.mjs",
    "verify:precommit:android-size": "node scripts/android/verify-apk-size-precommit.mjs --require-apk",
    "verify:release:page-contract": "node scripts/release/verify-android-release-page-contract.mjs",
    "build:android:release": "bash scripts/android/build-release-apk.sh --skip-install",
    "build:android:release:smoke": "bash scripts/android/build-release-apk.sh --temp-keystore --skip-install",
    "build:android:release:smoke:arm64": "bash scripts/android/build-release-apk.sh --temp-keystore --skip-install --architectures arm64-v8a",
    "build:android:release:smoke:shrink": "bash scripts/android/build-release-apk.sh --temp-keystore --skip-install --enable-minify --enable-resource-shrink",
    "build:android:release:smoke:arm64-shrink": "bash scripts/android/build-release-apk.sh --temp-keystore --skip-install --architectures arm64-v8a --enable-minify --enable-resource-shrink",
    "build:android:release:smoke:legacy": "bash scripts/android/build-release-apk.sh --temp-keystore --skip-install --enable-legacy-packaging",
    "build:android:release:smoke:legacy-shrink": "bash scripts/android/build-release-apk.sh --temp-keystore --skip-install --enable-legacy-packaging --enable-minify --enable-resource-shrink",
    "build:android:clean": "cd android && ./gradlew clean",
    "build:ios:debug": "expo run:ios --configuration Debug",
    "build:ios:release": "cd ios && xcodebuild -workspace MistapMediaCleaner.xcworkspace -scheme MistapMediaCleaner -configuration Release -sdk iphoneos build",
    "build:ios:clean": "cd ios && xcodebuild clean"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "expo": "~54.0.33",
    "expo-background-task": "~1.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-video": "~3.0.16",
    "expo-video-thumbnails": "~10.0.8",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@rnx-kit/metro-resolver-symlinks": "^0.2.11",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0-alpha.6",
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.0",
    "agent-device": "^0.14.7",
    "patch-package": "^8.0.1",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  },
  "private": true
}
