{
  "name": "app-cleaner",
  "version": "0.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest",
    "test:observability": "vitest --run src/services/observability src/application/__tests__/AppErrorBoundary.test.tsx src/application/__tests__/AppObservabilityBootstrap.test.tsx",
    "test:maestro:smoke": "bash scripts/android/run-maestro-smoke.sh",
    "typecheck": "tsc --noEmit",
    "page:build": "cd page && npm run build",
    "page:dev": "cd page && npm run dev",
    "page:preview": "cd page && npm run preview",
    "page:deploy": "cd page && npm run deploy",
    "page:deploy:prod": "cd page && npm run deploy:prod",
    "export:android": "expo export --platform android",
    "prebuild:android": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "run:android:debug": "expo run:android --variant debug",
    "build:android:debug": "bash scripts/android/build-debug-apk.sh --skip-install",
    "assemble:android:debug": "cd android && ./gradlew assembleDebug",
    "assemble:android:release": "cd android && ./gradlew assembleRelease",
    "prepare:android:keystore": "node scripts/android/prepare-keystore.mjs",
    "verify:android:debug": "node scripts/android/verify-debug-artifact.mjs android/app/build/outputs/apk/debug/app-debug.apk",
    "metadata:android:debug": "node scripts/android/collect-debug-metadata.mjs android/app/build/outputs/apk/debug/app-debug.apk",
    "verify:android:release": "node scripts/android/verify-release-artifact.mjs android/app/build/outputs/apk/release/app-release.apk",
    "metadata:android:release": "node scripts/android/collect-release-metadata.mjs android/app/build/outputs/apk/release/app-release.apk",
    "build:android:release": "bash scripts/android/build-release-apk.sh --skip-install",
    "build:android:clean": "cd android && ./gradlew clean",
    "build:ios:debug": "expo run:ios --configuration Debug",
    "build:ios:release": "cd ios && xcodebuild -workspace MistapMediaCleaner.xcworkspace -scheme MistapMediaCleaner -configuration Release -sdk iphoneos build",
    "build:ios:clean": "cd ios && xcodebuild clean"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@shopify/flash-list": "^2.3.1",
    "@expo/vector-icons": "15.1.1",
    "base64-js": "^1.5.1",
    "buffer": "^6.0.3",
    "expo": "~54.0.33",
    "expo-background-task": "~1.0.10",
    "expo-file-system": "~19.0.21",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-video": "~3.0.16",
    "expo-video-thumbnails": "~10.0.8",
    "form-data": "^4.0.5",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-polyfill-globals": "^3.1.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0-alpha.6",
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.0",
    "patch-package": "^8.0.1",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  },
  "private": true
}
